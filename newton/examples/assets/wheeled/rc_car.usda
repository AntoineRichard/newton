    def Scope "Joints"
    {
        def PhysicsPrismaticJoint "rc_front_left_suspension" (
            prepend apiSchemas = ["PhysicsDriveAPI:linear"]
        )
        {
            float drive:linear:physics:damping = 30
            float drive:linear:physics:maxForce = inf
            float drive:linear:physics:stiffness = 800
            float drive:linear:physics:targetPosition = 0
            float drive:linear:physics:targetVelocity = 0
            uniform token drive:linear:physics:type = "force"
            uniform token physics:axis = "Z"
            rel physics:body0 = </rc_car/RigidBodies/rc_car_chassis>
            rel physics:body1 = </rc_car/RigidBodies/rc_front_left_suspension_link>
            point3f physics:localPos0 = (0.162, 0.148, -0.022)
            point3f physics:localPos1 = (0, 0, 0)
            quatf physics:localRot0 = (1, 0, 0, 0)
            quatf physics:localRot1 = (1, 0, 0, 0)
